{
  "id": "human-gate-message",
  "kind": "extension",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "enabled": {
        "type": "boolean"
      },
      "timeoutSeconds": {
        "type": "number",
        "default": 300
      },
      "allowAgents": {
        "type": "array",
