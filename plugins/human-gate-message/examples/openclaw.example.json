{
  "plugins": {
    "allow": ["human-gate-message"],
    "load": {
      "paths": ["/path/to/openclaw-company-orchestration-proposal/plugins/human-gate-message"]
    },
    "entries": {
      "human-gate-message": {
        "enabled": true,
        "timeoutSeconds": 300,
