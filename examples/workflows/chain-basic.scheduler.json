{
  "workflow_id": "chain-basic.scheduler.v1",
  "owner": "zoe",
  "mode": "chain-basic",
  "steps": [
    {
      "id": "init_registry",
      "type": "control.init_registry"
    },
    {
      "id": "step_a",
      "type": "control.inline_payload",
      "state": "running",
      "output": {
        "status": "ok",
        "topic": "{{request.topic}}"
      },
      "summary": "step_a 完成"
    },
    {
      "id": "step_b",
      "type": "control.inline_payload",
      "state": "completed",
      "output": {
        "status": "ok",
        "target": "{{request.target}}",
        "message": "{{request.topic}} -> {{request.target}}"
      },
      "summary": "step_b 完成"
    },
    {
      "id": "final_callback",
      "type": "callback.send_once",
      "payloadFields": [
        "task_id",
        "workflow_id",
        "workflow_state"
      ],
      "continuation": {
        "next_step": "review_result_and_decide_followup_dispatch",
        "next_owner": "main",
        "next_backend": "manual",
        "auto_continue_if": [],
        "stop_if": [
          "no_follow_up_needed",
          "manual_closeout"
        ],
        "stopped_because": "workflow_completed"
      },
      "summary": {
        "workflow": "chain-basic",
        "ordered_steps": [
          "step_a",
          "step_b",
          "final_callback"
        ],
        "evidence_keys": [
          "input",
          "step_a",
          "step_b"
        ]
      }
    }
  ]
}
