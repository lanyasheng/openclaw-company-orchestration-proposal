{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://openclaw.local/schemas/trading_callback_envelope.v1.schema.json",
  "title": "Trading Roundtable Canonical Callback Envelope v1",
  "description": "标准化 trading roundtable 子任务回调 Schema。参考协议：docs/protocols/trading_roundtable_auto_execution_protocol_v1.md",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "envelope_version",
    "adapter",
    "scenario",
    "batch_id",
    "backend_terminal_receipt",
    "business_callback_payload",
    "adapter_scoped_payload",
    "orchestration_contract",
    "source"
  ],
  "properties": {
    "envelope_version": {
      "type": "string",
      "const": "canonical_callback_envelope.v1",
      "description": "Envelope 版本标识"
    },
    "adapter": {
      "type": "string",
      "const": "trading_roundtable",
      "description": "Adapter 类型"
    },
    "scenario": {
      "type": "string",
      "const": "trading_roundtable",
      "description": "Scenario 类型"
    },
    "batch_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^trading_batch_[A-Za-z0-9._-]+$",
      "description": "批次 ID，全局唯一"
    },
    "packet_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^pkt_[A-Za-z0-9._:-]+$",
      "description": "Packet ID，全局唯一"
    },
    "task_id": {
      "type": "string",
      "minLength": 1,
      "pattern": "^tsk_[A-Za-z0-9._:-]+$",
      "description": "任务 ID，全局唯一"
    },
    "completed_at": {
      "type": "string",
      "format": "date-time",
      "description": "完成时间戳（ISO 8601）"
    },
    
    "backend_terminal_receipt": {
      "type": "object",
      "description": "后端执行终态收据（由 harness/runtime 填充）",
      "additionalProperties": false,
      "required": [
        "receipt_version",
        "backend",
        "terminal_status",
        "artifact_paths",
        "dispatch_readiness"
      ],
      "properties": {
        "receipt_version": {
          "type": "string",
          "const": "tmux_terminal_receipt.v1"
        },
        "backend": {
          "type": "string",
          "const": "tmux"
        },
        "terminal_status": {
          "type": "string",
          "enum": ["completed", "failed", "blocked"],
          "description": "终态状态"
        },
        "artifact_paths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          },
          "description": "产出物路径列表，不得为空，必须至少包含 terminal.json"
        },
        "run_handle": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "run_id": { "type": "string" },
            "child_session_key": { "type": "string" },
            "pid": { "type": "integer" },
            "exit_code": { "type": "integer" }
          }
        },
        "dispatch_readiness": {
          "type": "boolean",
          "description": "是否准备好进入下一步 dispatch"
        }
      }
    },
    
    "business_callback_payload": {
      "type": "object",
      "description": "业务回调 payload（由 trading 执行链填写）",
      "additionalProperties": true,
      "required": [
        "tradability_score",
        "tradability_reason",
        "decision"
      ],
      "properties": {
        "tradability_score": {
          "type": "number",
          "minimum": 0.0,
          "maximum": 1.0,
          "description": "可交易性评分 [0.0, 1.0]"
        },
        "tradability_reason": {
          "type": "string",
          "minLength": 1,
          "description": "评分理由"
        },
        "decision": {
          "type": "string",
          "enum": ["PASS", "FAIL", "DEGRADED", "BLOCKED"],
          "description": "业务决策"
        },
        "blocked_reason": {
          "type": ["string", "null"],
          "description": "被阻塞的原因（如 decision=BLOCKED）"
        },
        "degraded_reason": {
          "type": ["string", "null"],
          "description": "降级的原因（如 decision=DEGRADED）"
        },
        "trading_roundtable": {
          "type": "object",
          "description": "Trading 特定业务字段",
          "additionalProperties": true
        }
      }
    },
    
    "adapter_scoped_payload": {
      "type": "object",
      "description": "Adapter 特定 payload（由 trading 执行链填写）",
      "additionalProperties": false,
      "required": [
        "adapter",
        "schema",
        "payload"
      ],
      "properties": {
        "adapter": {
          "type": "string",
          "const": "trading_roundtable"
        },
        "schema": {
          "type": "string",
          "const": "trading_roundtable_callback.v1"
        },
        "payload": {
          "type": "object",
          "additionalProperties": false,
          "required": ["packet", "roundtable"],
          "properties": {
            "packet": {
              "type": "object",
              "description": "Phase1 Packet Truth",
              "additionalProperties": true,
              "required": [
                "packet_version",
                "packet_id",
                "batch_id",
                "scenario",
                "owner"
              ],
              "properties": {
                "packet_version": {
                  "type": "string",
                  "const": "trading_roundtable_v1"
                },
                "packet_id": { "type": "string" },
                "batch_id": { "type": "string" },
                "scenario": { "type": "string" },
                "owner": { "type": "string" },
                "generated_at": { "type": "string", "format": "date-time" }
              }
            },
            "roundtable": {
              "type": "object",
              "description": "Roundtable 结论",
              "additionalProperties": true,
              "required": [
                "conclusion",
                "blocker",
                "owner",
                "next_step"
              ],
              "properties": {
                "conclusion": {
                  "type": "string",
                  "enum": ["PASS", "FAIL", "CONDITIONAL"]
                },
                "blocker": { "type": "string" },
                "owner": { "type": "string" },
                "next_step": { "type": "string" },
                "completion_criteria": { "type": "string" },
                "summary": { "type": "string" }
              }
            }
          }
        }
      }
    },
    
    "orchestration_contract": {
      "type": "object",
      "description": "编排契约（由 harness/runtime 填充）",
      "additionalProperties": true,
      "required": [
        "callback_envelope_schema",
        "next_step",
        "next_owner",
        "dispatch_readiness"
      ],
      "properties": {
        "callback_envelope_schema": {
          "type": "string",
          "const": "canonical_callback_envelope.v1"
        },
        "next_step": {
          "type": "string",
          "enum": ["acceptance_check", "closeout", "dispatch", "blocked"],
          "description": "下一步动作"
        },
        "next_owner": {
          "type": "string",
          "description": "下一步负责人"
        },
        "dispatch_readiness": {
          "type": "boolean",
          "description": "是否准备好 dispatch"
        },
        "gate_config_ref": {
          "type": "string",
          "description": "Gate 配置引用路径"
        },
        "closeout_requirements": {
          "type": "object",
          "properties": {
            "acceptance_checklist": { "type": "boolean" },
            "git_closeout": { "type": "boolean" },
            "push_required": { "type": "boolean" }
          }
        }
      }
    },
    
    "source": {
      "type": "object",
      "description": "Callback 来源元数据",
      "additionalProperties": true,
      "required": [
        "adapter",
        "runner",
        "label"
      ],
      "properties": {
        "adapter": { "type": "string" },
        "runner": { "type": "string" },
        "label": { "type": "string" },
        "business_payload_source": { "type": "string" },
        "backend_terminal_receipt_schema": { "type": "string" },
        "business_callback_schema": { "type": "string" }
      }
    }
  }
}
